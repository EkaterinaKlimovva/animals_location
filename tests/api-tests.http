  "role": "INVALID_ROLE"
}

### ========== Тесты 2 этапа ==========

### ========== Комплексные сценарии работы с животными ==========

### Позитивный тест: Полный жизненный цикл животного
### Шаг 1: Создание животного с типами и локацией
POST {{baseUrl}}/animals
Authorization: Basic {{base64}}
Content-Type: application/json

{
  "animalTypes": [1, 2],
  "weight": 4.5,
  "length": 0.45,
  "height": 0.25,
  "gender": "FEMALE",
  "chipperId": 1,
  "chippingLocationId": 1
}

### Шаг 2: Добавление посещенных локаций
POST {{baseUrl}}/animals/1/locations
Authorization: Basic {{base64}}
Content-Type: application/json

{
  "locationPointId": 2,
  "visitedAt": "2025-01-15T10:30:00.000Z"
}

### Шаг 3: Добавление еще одной локации
POST {{baseUrl}}/animals/1/locations
Authorization: Basic {{base64}}
Content-Type: application/json

{
  "locationPointId": 3,
  "visitedAt": "2025-02-20T14:15:00.000Z"
}

### Шаг 4: Получение истории перемещений с фильтрацией по времени
GET {{baseUrl}}/animals/1/locations?startDateTime=2025-01-01T00:00:00.000Z&endDateTime=2025-01-31T23:59:59.999Z
Authorization: Basic {{base64}}

### Шаг 5: Обновление статуса жизни на DEAD
PUT {{baseUrl}}/animals/1
Authorization: Basic {{base64}}
Content-Type: application/json

{
  "lifeStatus": "DEAD",
  "deathDateTime": "2025-03-01T12:00:00.000Z"
}

### ========== Продвинутый поиск и фильтрация ==========

### Поиск животных с множественными фильтрами
GET {{baseUrl}}/animals/search?chipperId=1&lifeStatus=ALIVE&gender=MALE&startDateTime=2024-01-01T00:00:00.000Z&endDateTime=2025-12-31T23:59:59.999Z&from=0&size=5
Authorization: Basic {{base64}}

### Поиск с пагинацией - вторая страница
GET {{baseUrl}}/animals/search?from=5&size=5
Authorization: Basic {{base64}}

### Поиск аккаунтов с комплексными фильтрами
GET {{baseUrl}}/accounts/search?firstName=А&lastName=И&email=mail&from=0&size=3
Authorization: Basic {{base64}}

### ========== Работа со связанными сущностями ==========

### Создание животного с новым типом
### Сначала создаем новый тип
POST {{baseUrl}}/animals/types
Authorization: Basic {{base64}}
Content-Type: application/json

{
  "type": "Экзотический"
}

### Затем создаем животное с новым типом
POST {{baseUrl}}/animals
Authorization: Basic {{base64}}
Content-Type: application/json

{
  "animalTypes": [3],
  "weight": 2.1,
  "length": 0.3,
  "height": 0.2,
  "gender": "OTHER",
  "chipperId": 1,
  "chippingLocationId": 2
}

### Добавление дополнительного типа существующему животному
POST {{baseUrl}}/animals/1/types
Authorization: Basic {{base64}}
Content-Type: application/json

{
  "typeId": 3
}

### Проверка типов животного после добавления
GET {{baseUrl}}/animals/1
Authorization: Basic {{base64}}

### ========== Тесты целостности данных ==========

### Попытка удалить точку локации, используемую для чипирования
DELETE {{baseUrl}}/locations/1
Authorization: Basic {{base64}}

### Попытка удалить аккаунт, который является чипером для животных
DELETE {{baseUrl}}/accounts/1
Authorization: Basic {{base64}}

### Попытка удалить тип животного, используемый в AnimalOnType
DELETE {{baseUrl}}/animals/types/1
Authorization: Basic {{base64}}

### ========== Граничные случаи и edge cases ==========

### Создание животного с максимальными валидными значениями
POST {{baseUrl}}/animals
Authorization: Basic {{base64}}
Content-Type: application/json

{
  "animalTypes": [1],
  "weight": 999.99,
  "length": 99.99,
  "height": 99.99,
  "gender": "MALE",
  "chipperId": 1,
  "chippingLocationId": 1
}

### Создание животного с минимальными валидными значениями
POST {{baseUrl}}/animals
Authorization: Basic {{base64}}
Content-Type: application/json

{
  "animalTypes": [1],
  "weight": 0.01,
  "length": 0.01,
  "height": 0.01,
  "gender": "FEMALE",
  "chipperId": 1,
  "chippingLocationId": 1
}

### Создание локации на границах координат
POST {{baseUrl}}/locations
Authorization: Basic {{base64}}
Content-Type: application/json

{
  "latitude": 90,
  "longitude": 180
}

### Создание локации на отрицательных границах
POST {{baseUrl}}/locations
Authorization: Basic {{base64}}
Content-Type: application/json

{
  "latitude": -90,
  "longitude": -180
}

