{
  "name": "api-jest-tests",
  "version": "1.0.0",
  "description": "Jest-based API tests for Animals Location system",
  "main": "jest.config.js",
  "type": "module",
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "test:watch": "node --experimental-vm-modules node_modules/.bin/jest --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/.bin/jest --coverage",
    "test:verbose": "node --experimental-vm-modules node_modules/.bin/jest --verbose",
    "test:debug": "node --inspect --experimental-vm-modules node_modules/.bin/jest --runInBand",
    "test:specific": "node --experimental-vm-modules node_modules/.bin/jest --testNamePattern",
    "test:file": "node --experimental-vm-modules node_modules/.bin/jest --testPathPattern",
    "test:report": "node --experimental-vm-modules node_modules/.bin/jest --coverage --coverageReporters=html,text,lcov"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/sinon": "^10.0.0",
    "axios": "^1.6.0",
    "babel-jest": "^30.3.0",
    "dotenv": "^16.0.0",
    "jest": "^29.5.0",
    "jest-extended": "^6.0.0",
    "jest-html-reporters": "^3.1.7",
    "jest-sonar-reporter": "^2.0.0",
    "sinon": "^17.0.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "api",
    "testing",
    "jest",
    "typescript",
    "validation",
    "sinon"
  ],
  "author": "API Test Suite",
  "license": "MIT"
}
