{
  "name": "animals_location",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "build": "rimraf dist && tsc --noEmitOnError false",
    "run": "npm run build && tsx dist/app/index.js",
    "run:with-tests": "npm run test:continue && npm run build && tsx dist/app/index.js",
    "lint": "eslint . ",
    "lint:fix": "eslint . --fix",
    "db:migrate": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "test": "jest --forceExit",
    "test:watch": "jest --watch --forceExit",
    "test:coverage": "jest --coverage --forceExit",
    "test:unit": "jest --testPathPatterns=tests/src/controllers --forceExit",
    "test:integration": "jest --testPathPatterns=tests/src/integration --forceExit",
    "test:verbose": "jest --verbose --forceExit",
    "test:detailed": "jest --verbose --coverage --forceExit",
    "test:continue": "jest --forceExit --passWithNoTests || true"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EkaterinaKlimovva/animals_location.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/EkaterinaKlimovva/animals_location/issues"
  },
  "homepage": "https://github.com/EkaterinaKlimovva/animals_location#readme",
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.3",
    "@types/pg": "^8.11.11",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "jest": "^30.3.0",
    "jest-junit": "^16.0.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.0",
    "globals": "^17.4.0",
    "pg": "^8.20.0",
    "prisma": "^7.4.2",
    "typescript-eslint": "^8.56.1",
    "zod": "^4.3.6"
  }
